{
  "manifest_version": 3,
  "key": "",
  "name": "KB Tracker",
  "version": "0.3.0",
  "description": "Tracks private lobby & limited format game data for Karabast (Star Wars Unlimited).",
  "permissions": [
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "943581460966-b1ij58l01ppvah13mvapkjvp843jru3l.apps.googleusercontent.com",
    "scopes": ["email", "profile", "openid"]
  },
  "host_permissions": [
    "https://play.karabast.net/*",
    "https://*.karabast.net/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://play.karabast.net/*",
        "https://*.karabast.net/*"
      ],
      "js": ["src/inject/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://play.karabast.net/*",
        "https://*.karabast.net/*"
      ],
      "js": ["src/content/content.ts"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": [
        "https://play.karabast.net/*",
        "https://*.karabast.net/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "KB Tracker",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "kb-tracker@karabast.extension",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
